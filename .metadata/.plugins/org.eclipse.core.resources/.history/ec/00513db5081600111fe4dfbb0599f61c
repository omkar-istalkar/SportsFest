<%@ taglib uri="http://java.sun.com/jsp/jstl/core" prefix="c" %>

<div class="fade-in">

    <div class="d-flex justify-content-between mb-3">
        <h5 class="mb-0">All Events</h5>

        <button class="btn btn-primary btn-sm"
                onclick="openModal('/admin/create-event','Create Event')">
            + Create Event
        </button>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Deadline</th>
                <th>Status</th>
                <th width="380">Actions</th>
            </tr>
            </thead>

            <tbody>
            <c:forEach var="event" items="${events}">
                <tr>
                    <td>${event.id}</td>
                    <td>${event.name}</td>
                    <td>${event.deadline}</td>

                    <td>
                        <span class="badge ${event.active ? 'bg-success' : 'bg-secondary'}">
                            ${event.active ? 'Active' : 'Inactive'}
                        </span>
                    </td>

                    <td>

                        <button class="btn btn-sm btn-info"
                                onclick="openModal('/admin/fields/${event.id}','Fields - ${event.name}')">
                            Fields
                        </button>

                        <button class="btn btn-sm btn-warning"
                                onclick="openModal('/admin/edit-event/${event.id}','Edit Event')">
                            Edit
                        </button>

                        <a href="/admin/delete-event/${event.id}"
                           class="btn btn-sm btn-danger"
                           onclick="return confirm('Are you sure?')">
                            Delete
                        </a>

                        <button class="btn btn-sm btn-primary"
                                onclick="openModal('/admin/preview/${event.id}','Preview - ${event.name}')">
                            Preview
                        </button>

                        <button class="btn btn-sm btn-dark"
                                onclick="openModal('/admin/event-responses/${event.id}',
                                                   'Registrations - ${event.name}')">
                            View Responses
                        </button>

                    </td>
                </tr>
            </c:forEach>
            </tbody>
        </table>
    </div>

</div>