<%@ taglib uri="http://java.sun.com/jsp/jstl/core" prefix="c"%>

<div class="container mt-5">

<div class="card shadow">
<div class="card-body">

<h4>Registration Details</h4>
<hr>

<p><strong>Registration ID:</strong> ${registration.registrationId}</p>
<p><strong>Name:</strong> ${registration.captainName}</p>
<p><strong>Email:</strong> ${registration.email}</p>
<p><strong>Event:</strong> ${registration.event.name}</p>

<c:if test="${registration.teamName != null}">
<p><strong>Team:</strong> ${registration.teamName}</p>
</c:if>

<hr>

<h6>Custom Fields</h6>

<c:if test="${not empty dynamicData}">
    <c:forEach var="entry" items="${dynamicData}">
        <p>
            <strong>Field ${entry.key}:</strong>
            ${entry.value}
        </p>
    </c:forEach>
</c:if>

<hr>

<span class="badge 
    ${registration.status == 'PENDING' ? 'bg-warning text-dark' :
      registration.status == 'APPROVED' ? 'bg-success' :
      'bg-danger'}">
    ${registration.status}
</span>

</div>
</div>
</div>