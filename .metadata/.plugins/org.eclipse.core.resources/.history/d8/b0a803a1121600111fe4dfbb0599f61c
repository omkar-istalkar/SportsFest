<%@ taglib uri="http://java.sun.com/jsp/jstl/core" prefix="c"%>

<div class="p-3">

    <h5>${registration.event.name}</h5>
    <hr>

    <div class="row mb-3">
        <div class="col-md-6">
            <strong>Captain:</strong> ${registration.captainName}
        </div>
        <div class="col-md-6">
            <strong>Email:</strong> ${registration.email}
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <strong>Phone:</strong> ${registration.phone}
        </div>
        <div class="col-md-6">
            <strong>Team:</strong> ${registration.teamName}
        </div>
    </div>

    <div class="mb-3">
        <strong>Status:</strong>
        <span class="badge 
            ${registration.status == 'PENDING' ? 'bg-warning text-dark' :
              registration.status == 'APPROVED' ? 'bg-success' :
              'bg-danger'}">
            ${registration.status}
        </span>
    </div>

    <hr>

    <h6 class="mb-3">Custom Responses</h6>

    <c:if test="${empty dynamicFields}">
        <p class="text-muted">No custom fields submitted.</p>
    </c:if>

    <c:forEach var="entry" items="${dynamicFields}">
        <div class="mb-2">
            <strong>${entry.key}:</strong>
            ${entry.value}
        </div>
    </c:forEach>

</div>