<%@ taglib uri="http://java.sun.com/jsp/jstl/core" prefix="c"%>

<div class="fade-in">

<h4 class="mb-4">Registrations</h4>

<div class="table-responsive">
<table class="table align-middle">

<thead class="table-light">
<tr>
    <th>ID</th>
    <th>Participant</th>
    <th>Event</th>
    <th>Status</th>
    <th width="200">Actions</th>
</tr>
</thead>

<tbody>

<c:forEach var="reg" items="${registrations}">
<tr>

<td>REG-${reg.id}</td>

<td>
    <strong>${reg.captainName}</strong><br>
    <small class="text-muted">${reg.email}</small>
</td>

<td>${reg.event.name}</td>

<td>
    <span class="badge 
        ${reg.status == 'PENDING' ? 'bg-warning text-dark' :
          reg.status == 'APPROVED' ? 'bg-success' :
          'bg-danger'}">
        ${reg.status}
    </span>
</td>

<td>

<c:if test="${reg.status == 'PENDING'}">
    <button class="btn btn-sm btn-success"
            onclick="approveReg(${reg.id})">
        Approve
    </button>

    <button class="btn btn-sm btn-danger"
            onclick="rejectReg(${reg.id})">
        Reject
    </button>
</c:if>

<button class="btn btn-sm btn-outline-primary"
        onclick="openModal('/admin/view-registration/${reg.id}',
                           'Registration Details')">
    <i class="bi bi-eye"></i>
</button>

</td>

</tr>
</c:forEach>

</tbody>
</table>
</div>

</div>

<script>
function approveReg(id) {
    $.get('/admin/approve-registration/' + id, function() {
        loadPage('/admin/registrations');
    });
}

function rejectReg(id) {
    $.get('/admin/reject-registration/' + id, function() {
        loadPage('/admin/registrations');
    });
}
</script>