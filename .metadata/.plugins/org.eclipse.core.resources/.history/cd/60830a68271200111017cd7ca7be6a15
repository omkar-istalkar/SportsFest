<%@ taglib uri="http://java.sun.com/jsp/jstl/core" prefix="c" %>

<html>
	<head>
		<title>Event List</title>
	</head>
	<body>
		<h2>All Events</h2>
		
		<a href="/admin/create-event">Create New Event</a>
		<br><br>
		
		<table border="2">
			<tr>
				<th>ID</th>
				<th>Name</th>
				<th>Description</th>
				<th>Active</th>
			</tr>
			
			<c:forEach var="event" items="${events}">
				<tr>
					<td>${event.id}</td>
					<td>${event.name}</td>
					<td>${event.description}</td>
					<td>${event.deadline}</td>
					<td>${event.active}</td>
				</tr>
			</c:forEach>
		</table>
	</body>
</html>